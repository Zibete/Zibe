<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Zibe.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/selector_zibe_button_primary</item>
        <item name="android:textColor">@color/selector_zibe_button_text</item>
        <item name="android:textAppearance">@style/TextAppearance.Zibe.ActionLabel</item>

        <item name="iconSize">@dimen/icon_size</item>
        <item name="iconTint">@color/selector_zibe_button_text</item>

        <item name="android:minHeight">@dimen/zibe_btn_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>

        <item name="cornerRadius">@dimen/zibe_btn_corner</item>
        <item name="android:elevation">@dimen/zibe_btn_elevation</item>

        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Zibe.Button</item>

        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Zibe.Button.Secondary" parent="Zibe.Button.Primary">
        <item name="android:backgroundTint">@color/selector_zibe_button_secondary</item>
    </style>

    <style name="Zibe.ExtendedFab" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="backgroundTint">@color/selector_zibe_extfab_bg</item>
        <item name="iconTint">@color/selector_zibe_extfab_content</item>
        <item name="android:textColor">@color/selector_zibe_extfab_content</item>

        <item name="cornerRadius">@dimen/zibe_btn_corner</item>
        <item name="android:minHeight">@dimen/zibe_btn_height</item>
        <item name="android:elevation">@dimen/zibe_btn_elevation</item>

        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/zibe_text_size_label</item>
        <item name="fontFamily">@font/poppins_medium</item>

        <item name="android:minWidth">@dimen/fab_min_width</item>
        <item name="android:paddingStart">@dimen/fab_padding_h</item>
        <item name="android:paddingEnd">@dimen/fab_padding_h</item>
        <item name="iconPadding">@dimen/fab_icon_padding</item>

    </style>

    <style name="ShapeAppearance.Zibe.Button">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/zibe_btn_corner</item>
    </style>

    <style name="Zibe.IconButton" parent="Widget.Material3.Button.Icon">
        <!-- Tamaño -->
        <item name="android:layout_width">@dimen/zibe_icon_btn_size</item>
        <item name="android:layout_height">@dimen/zibe_icon_btn_size</item>
<!--        <item name="android:minWidth">@dimen/zibe_icon_btn_size</item>-->
<!--        <item name="android:minHeight">@dimen/zibe_icon_btn_size</item>-->

        <!-- Centro real -->
        <item name="android:gravity">center</item>

        <item name="android:padding">0dp</item>
<!--        <item name="android:insetLeft">0dp</item>-->
<!--        <item name="android:insetRight">0dp</item>-->
<!--        <item name="android:insetTop">0dp</item>-->
<!--        <item name="android:insetBottom">0dp</item>-->

        <!-- MaterialButton paddings -->
        <item name="iconPadding">0dp</item>
<!--        <item name="android:drawablePadding">0dp</item>-->

        <!-- Icon -->
        <item name="iconSize">@dimen/zibe_icon_size</item>
        <item name="iconTint">?attr/colorOnSurface</item>

        <!-- IMPORTANTE: este es el que menos “sesgo” mete -->
        <item name="iconGravity">textStart</item>

        <!-- Fondo / ripple -->
<!--        <item name="backgroundTint">@android:color/transparent</item>-->
        <item name="rippleColor">?attr/colorOnSurfaceVariant</item>

        <!-- Sin texto -->
        <item name="android:text">@null</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
