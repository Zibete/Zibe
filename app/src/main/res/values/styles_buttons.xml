<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Botón por defecto (violeta). Usá Zibe.Button.Primary para rosa -->
    <style name="Zibe.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/zibe_button_bg_selector</item>

        <!-- Disabled -> hint (ColorStateList) -->
        <item name="android:textColor">@color/zibe_button_text_selector</item>

        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:elevation">3dp</item>
    </style>

    <style name="Zibe.Button.Primary" parent="Zibe.Button">
        <item name="android:backgroundTint">@color/zibe_btn_primary</item>
    </style>

</resources>
