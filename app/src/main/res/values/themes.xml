<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- =========================================================
         THEME (Material 3) - Base
         ========================================================= -->
    <style name="Theme.Zibe" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Typography -->
        <item name="android:fontFamily">@font/poppins</item>
        <item name="fontFamily">@font/poppins</item>

        <!-- Material 3 Text tokens -->
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Zibe.H2</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Zibe.Subtitle</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Zibe.Body</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Zibe.ActionLabel</item>

        <!-- Color scheme (M3 tokens) -->
        <item name="colorPrimary">@color/zibe_pink</item>
        <item name="colorOnPrimary">@color/zibe_text_light</item>

        <item name="colorSecondary">@color/zibe_purple</item>
        <item name="colorOnSecondary">@color/zibe_text_light</item>

        <item name="colorSurface">@color/zibe_dark_bg</item>
        <item name="colorOnSurface">@color/zibe_text_light</item>

        <item name="colorSurfaceVariant">@color/zibe_surface</item>
        <item name="colorOnSurfaceVariant">@color/zibe_text_light</item>

        <item name="colorOutline">@color/zibe_pink</item>

        <!-- System UI -->
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:windowBackground">@drawable/bg_gradient_zibe</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Widget defaults -->
        <item name="textInputStyle">@style/Zibe.Input</item>
        <item name="bottomNavigationStyle">@style/Zibe.BottomNav</item>
        <item name="toolbarStyle">@style/Zibe.Toolbar</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Zibe.AlertDialog</item>
        <item name="materialCalendarTheme">@style/ThemeOverlay.Zibe.MaterialCalendar</item>

        <!-- Menu / Search (global) -->
        <item name="popupMenuStyle">@style/Widget.Zibe.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.Zibe.PopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/Widget.Zibe.PopupMenu</item>
        <item name="searchViewStyle">@style/Widget.Zibe.SearchView</item>
    </style>



</resources>
