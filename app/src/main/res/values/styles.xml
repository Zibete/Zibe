<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- =========================================================
         COMPONENT STYLES (Views)
         ========================================================= -->

    <!-- Base ThemeOverlay.Zibe -->
    <style name="ThemeOverlay.Zibe" parent="ThemeOverlay.Material3" />

    <!-- Toolbar -->
    <style name="Zibe.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="subtitleTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="titleTextAppearance">@style/TextAppearance.Zibe.Brand.Subtitle</item>
        <item name="drawerArrowStyle">@style/Widget.Zibe.DrawerArrowOnGradient</item>
        <item name="actionOverflowButtonStyle">@style/Widget.Zibe.OverflowButtonOnGradient</item>
        <!-- Para iconos: usar app:navigationIconTint en el XML del toolbar -->
    </style>

    <!-- Navigation drawer -->
    <style name="Zibe.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="itemIconTint">@color/zibe_nav_inactive</item>
        <item name="itemTextColor">@color/zibe_nav_inactive</item>
        <item name="itemRippleColor">@color/zibe_pink</item>
    </style>

    <!-- PopupMenu -->
    <style name="ThemeOverlay.Zibe.PopupMenu" parent="ThemeOverlay.Material3">
        <item name="popupMenuStyle">@style/Widget.Zibe.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.Zibe.PopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/Widget.Zibe.PopupMenu</item>
    </style>

    <!-- BottomNavigation -->
    <style name="ThemeOverlay.Zibe.BottomNav" parent="ThemeOverlay.Material3.BottomNavigationView">
        <item name="itemIconTint">@drawable/bottom_nav_selector</item>
        <item name="itemTextColor">@drawable/bottom_nav_selector</item>
        <item name="itemRippleColor">@color/zibe_pink</item>
        <item name="itemActiveIndicatorStyle">@style/Zibe.BottomNav.ActiveIndicator.Pill</item>
    </style>

    <!-- BottomSheet -->
    <style name="Zibe.BottomSheetTheme" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Zibe.BottomSheet.Internal</item>
        <item name="materialButtonStyle">@style/Zibe.Button.Secondary</item>
    </style>

    <style name="Zibe.BottomSheet.Internal" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Zibe.BottomSheet</item>
        <item name="backgroundTint">?attr/colorSurface</item>
    </style>

    <style name="ShapeAppearance.Zibe.BottomSheet" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/corner_xxl</item>
        <item name="cornerSizeTopRight">@dimen/corner_xxl</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- =========================================================
         WIDGETS
         ========================================================= -->

    <style name="Zibe.BottomNav" parent="ThemeOverlay.Zibe.BottomNav" />

    <style name="Widget.Zibe.CircularLoading" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorSize">48dp</item>
        <item name="trackThickness">4dp</item>
        <item name="indicatorColor">?attr/colorPrimary</item>
        <item name="trackColor">?attr/colorSurfaceVariant</item>
    </style>

    <style name="Widget.Zibe.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu_zibe</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:elevation">8dp</item>
        <item name="android:dropDownVerticalOffset">12dp</item>
    </style>

    <style name="Widget.Zibe.SearchView" parent="Widget.AppCompat.SearchView">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textColorHint">?attr/colorOnSurface</item>
        <item name="closeIcon">@drawable/ic_close_rounded_24</item>
        <item name="searchIcon">@drawable/ic_search_rounded_24</item>
        <item name="queryBackground">@null</item>
        <item name="submitBackground">@null</item>
    </style>

    <style name="Widget.Zibe.DrawerArrowOnGradient" parent="Widget.AppCompat.DrawerArrowToggle">
        <item name="color">?attr/colorOnPrimary</item>
    </style>

    <style name="Widget.Zibe.OverflowButtonOnGradient" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">?attr/colorOnPrimary</item>
    </style>

</resources>
