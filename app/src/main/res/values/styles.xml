<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== TEMA BASE APP ===== -->
    <style name="AppTheme.Zibe" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Colores base -->
        <item name="colorPrimary">@color/zibe_purple</item>
        <item name="colorPrimaryVariant">@color/zibe_purple_dark</item>
        <item name="colorSecondary">@color/zibe_pink</item>
        <item name="colorAccent">@color/zibe_pink</item>
        <item name="colorControlActivated">@color/zibe_purple</item>

        <!-- Sistema -->
        <item name="android:statusBarColor">@color/zibe_night_start</item>
        <item name="android:navigationBarColor" tools:targetApi="lollipop">@color/zibe_night_end</item>
        <item name="android:windowBackground">@drawable/bg_gradient_zibe</item>

        <!-- Texto -->
        <item name="android:textColorPrimary">@color/zibe_text_light</item>
        <item name="android:textColorSecondary">@color/zibe_text_muted</item>
        <item name="android:textColorHint">@color/zibe_hint_text</item>

        <!-- Defaults de widgets -->
        <item name="materialButtonStyle">@style/Zibe.Button</item>
        <item name="textInputStyle">@style/Zibe.Input</item>
        <item name="bottomNavigationStyle">@style/Zibe.BottomNav</item>
        <item name="toolbarStyle">@style/Zibe.Toolbar</item>
        <item name="materialAlertDialogTheme">@style/Zibe.Dialog</item>
    </style>

    <!-- Tema Auth -->
    <style name="AuthTheme.Zibe" parent="AppTheme.Zibe">
        <item name="android:windowBackground">@drawable/bg_gradient_zibe</item>
    </style>

    <!-- ===== COMPAT CON NOMBRES EXISTENTES EN TUS LAYOUTS ===== -->
    <!-- activity_on_boarding.xml -->
    <style name="AppTheme.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/bg_gradient_zibe</item>
    </style>

    <!-- app_bar_main.xml / activity_chat.xml -->
    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar" />
    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light" />

    <!-- NavigationView en activity_main.xml -->
    <style name="NavViewStyle" parent="Widget.MaterialComponents.NavigationView">
        <item name="android:textColorPrimary">@color/zibe_text_light</item>
        <item name="android:textColorSecondary">@color/zibe_text_muted</item>
        <item name="itemIconTint">@color/zibe_nav_inactive</item>
        <item name="itemTextColor">@color/zibe_nav_inactive</item>
        <item name="itemRippleColor">@color/zibe_pink</item>
    </style>

    <!-- BottomNavigation en content_main.xml -->
    <style name="NavBottomStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/zibe_nav_bg</item>
        <item name="itemIconTint">@color/zibe_nav_inactive</item>
        <item name="itemTextColor">@color/zibe_nav_inactive</item>
        <item name="itemRippleColor">@color/zibe_pink</item>
    </style>

    <!-- filter_layout.xml / profile_photo_layout.xml -->
    <style name="AlertDialogApp" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@color/zibe_card</item>
        <item name="android:textColor">@color/zibe_text_light</item>
    </style>

    <!-- ===== WIDGETS ZIBE ===== -->
    <!-- Botón por defecto (violeta). Usá Zibe.Button.Primary para rosa -->
    <style name="Zibe.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/zibe_btn_secondary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:elevation">3dp</item>
    </style>

    <style name="Zibe.Button.Primary" parent="Zibe.Button">
        <item name="android:backgroundTint">@color/zibe_btn_primary</item>
    </style>

    <style name="Zibe.HintText" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/zibe_hint_text</item>
    </style>

    <style name="Zibe.Input" parent="Widget.MaterialComponents.TextInputLayout.FilledBox.Dense">
        <item name="boxBackgroundColor">@color/zibe_night_end</item>
        <item name="boxStrokeColor">@color/zibe_input_border</item>
        <item name="android:textColorHint">@color/zibe_hint_text</item> <!-- en reposo -->
        <item name="hintTextColor">@color/zibe_hint_text</item> <!-- flotante -->
        <item name="hintTextAppearance">@style/Zibe.HintText</item> <!-- refuerza color -->
        <!-- <item name="placeholderTextColor">@color/zibe_hint_text</item> -->
        <item name="startIconTint">@color/zibe_text_muted</item>
        <item name="endIconTint">@color/zibe_text_muted</item>
    </style>

    <!-- EditText interno (si lo aplicás aparte) -->
    <style name="Zibe.EditText" parent="Widget.MaterialComponents.TextInputEditText.FilledBox.Dense">
        <item name="android:textColor">@color/zibe_text_light</item>
        <item name="hintTextColor">@color/zibe_hint_text</item>
    </style>

    <style name="Zibe.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/zibe_nav_bg</item>
        <item name="itemIconTint">@color/zibe_nav_inactive</item>
        <item name="itemTextColor">@color/zibe_nav_inactive</item>
        <item name="itemRippleColor">@color/zibe_pink</item>
    </style>

    <style name="Zibe.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@drawable/bg_gradient_zibe</item>
        <item name="android:titleTextColor">@color/white</item>
        <item name="android:subtitleTextColor">@color/zibe_text_muted</item>
    </style>

    <style name="Zibe.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/zibe_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">3dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <!-- Utilidades que tus layouts referencian -->
    <style name="TextAppearance">
        <item name="actionMenuTextColor">@color/white</item>
        <item name="android:actionMenuTextColor">@color/white</item>
    </style>

    <style name="Arrow">
        <item name="colorControlNormal">@android:color/white</item>
    </style>

    <!-- Alias para compatibilidad si el manifest usa @style/AppTheme -->
    <style name="AppTheme" parent="AppTheme.Zibe"/>

    <!-- Usado por varias activities -->
    <style name="AppTheme.MainActivity" parent="AppTheme.Zibe">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Usado por ChatActivity -->
    <style name="AppThemeChat" parent="AppTheme.MainActivity">
        <!-- Solo si querés algo distinto para Chat -->
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <!-- Overlay solo para el DatePicker -->
    <style name="ZibeDatePickerOverlay" parent="ThemeOverlay.MaterialComponents.MaterialCalendar">
        <!-- Fuerzo violeta en todo lo interactivo -->
        <item name="colorPrimary">@color/zibe_purple</item>
        <item name="colorPrimaryVariant">@color/zibe_purple_dark</item>
        <item name="colorSecondary">@color/zibe_purple</item> <!-- evita que tome el rosa -->
        <item name="colorOnPrimary">@color/white</item>
        <!-- Opcionales de contraste/surface -->
        <item name="colorSurface">@color/zibe_card</item>
        <!-- <item name="materialCalendarDaySelectedForeground">@color/white</item> -->
        <!-- <item name="materialCalendarDaySelectedBackground">@color/zibe_purple</item> -->
    </style>

    <style name="Zibe.Rounded28" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <!-- Overlay específico para diálogos -->
    <style name="Zibe.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <!-- Colores de la tarjeta del diálogo -->
        <item name="colorSurface">@color/zibe_card</item>
        <item name="colorOnSurface">@color/zibe_text_light</item>

        <!-- Bordes redondeados del contenedor -->
        <item name="shapeAppearanceMediumComponent">@style/Zibe.Dialog.Shape</item>

        <!-- Forzar que los botones del diálogo sean TextButton (no MaterialButton sólido) -->
        <item name="materialButtonStyle">@style/Zibe.Dialog.TextButton</item>

        <!-- Opcional: tipografías de título y cuerpo -->
        <item name="textAppearanceHeadline6">@style/Zibe.Dialog.Title</item>
        <item name="textAppearanceBody2">@style/Zibe.Dialog.Body</item>
    </style>

    <style name="Zibe.Dialog.Shape" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Botón de diálogo tipo texto -->
    <style name="Zibe.Dialog.TextButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/zibe_pink</item>
        <item name="rippleColor">@color/zibe_pink_24</item>
    </style>

    <style name="Zibe.Dialog.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Zibe.Dialog.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/zibe_text_light</item>
    </style>

    <style name="Shape.Zibe.Card.Large" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>


</resources>
