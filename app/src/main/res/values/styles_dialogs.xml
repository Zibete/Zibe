<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- =========================================================
         AlertDialog (Material 3)
         ========================================================= -->
    <style name="ThemeOverlay.Zibe.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <!-- tokens del theme -->
        <item name="android:background">@color/snackbar_surface</item>

        <!-- Shape -->
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Zibe.Card</item>

        <!-- Text -->
        <item name="titleTextStyle">@style/TextAppearance.Zibe.Dialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.Zibe.Dialog.Body</item>

        <!-- Buttons -->
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Zibe.Dialog.TextButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Zibe.Dialog.TextButton</item>
    </style>

    <style name="Widget.Zibe.Dialog.TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.Zibe.Dialog.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Zibe.Dialog.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- =========================================================
         MaterialCalendar / DatePicker overlay
         ========================================================= -->
    <style name="ThemeOverlay.Zibe.MaterialCalendar" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="elevationOverlayEnabled">false</item>
        <item name="materialCalendarStyle">@style/Widget.Zibe.MaterialCalendar</item>
    </style>

    <style name="Widget.Zibe.MaterialCalendar" parent="Widget.Material3.MaterialCalendar">
        <item name="backgroundTint">@color/zibe_dark_bg</item>
    </style>

</resources>
