<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Zibe.Typography" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/poppins</item>
        <item name="fontFamily">@font/poppins</item>
    </style>

    <style name="Zibe.Text.Base" parent="Zibe.Typography">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="Zibe.Text.Medium" parent="Zibe.Text.Base">
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Zibe.Text.SemiBold" parent="Zibe.Text.Base">
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="Zibe.Text.Bold" parent="Zibe.Text.Base">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="Zibe.Text.Regular" parent="Zibe.Text.Base">
        <item name="android:textFontWeight">400</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Zibe.Text.Brand" parent="Zibe.Text.Bold">
        <item name="android:textSize">24sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

</resources>
