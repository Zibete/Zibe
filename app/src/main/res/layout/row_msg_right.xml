<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="@color/zibe_night_start"
    android:id="@+id/linearCardMsg">


    <LinearLayout
        android:layout_gravity="right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginVertical="2.5dp">



            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/linear_mensaje_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/chat_right"
                    android:layout_weight="1"
                    android:gravity="right"
                    android:visibility="gone">


                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tv_msg"
                            android:layout_marginHorizontal="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textIsSelectable="true"
                            android:paddingBottom="5dp"
                            android:paddingTop="2dp"
                            android:textSize="16sp"/>


                    </LinearLayout>



                </LinearLayout>

                <LinearLayout
                    android:id="@+id/linear_mensaje_audio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="2dp"
                    android:layout_marginVertical="2dp"
                    android:background="@drawable/chat_right"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/ic_play_pause"
                        android:layout_width="40dp"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="4dp"
                        android:src="@drawable/ic_baseline_play_arrow_24"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/marco_seekbar"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <SeekBar
                                android:id="@+id/seekBar"
                                android:layout_width="match_parent"
                                android:layout_marginTop="20dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_gravity="center"/>

                            <Chronometer
                                android:id="@+id/tv_timer"
                                android:layout_marginHorizontal="15dp"
                                android:layout_marginBottom="1dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_small"/>


                        </LinearLayout>

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/circleImgAudio"
                            android:layout_width="50dp"
                            android:layout_height="match_parent"
                            android:layout_marginVertical="4dp"/>


                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/linear_mensaje_pic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:padding="2dp"
                    android:background="@drawable/chat_right"
                    android:visibility="gone">

                    <androidx.coordinatorlayout.widget.CoordinatorLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/marco_seekbar">

                        <com.zibete.proyecto1.ui.ResizableImageView
                            android:id="@+id/img_pic"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"/>

                        <TextView
                            android:id="@+id/tv_notFound"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="No disponible"
                            android:visibility="gone"/>

                        <ProgressBar
                            android:id="@+id/loadingPhoto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:indeterminate="true"
                            android:layout_gravity="center"/>


                    </androidx.coordinatorlayout.widget.CoordinatorLayout>



                </LinearLayout>

                <TextView
                    android:id="@+id/hora_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:text="00:00"
                    android:textSize="12sp"
                    android:paddingBottom="3dp"
                    android:layout_marginStart="3dp"/>


                <RelativeLayout
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom">

                    <ImageView
                        android:id="@+id/checked"
                        android:layout_width="15dp"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_baseline_check_24"/>

                    <ImageView
                        android:id="@+id/checked2"
                        android:layout_width="15dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:src="@drawable/ic_baseline_check_24"/>

                </RelativeLayout>



            </LinearLayout>




        </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/selectedItem"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/transparent"/>


</androidx.cardview.widget.CardView>