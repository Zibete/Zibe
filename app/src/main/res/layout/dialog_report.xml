<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/colorA"
    android:orientation="vertical"
    android:layout_gravity="center">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        android:fillViewport="true"
        android:id="@+id/scrollable">


        <LinearLayout
            android:layout_marginVertical="50dp"
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingVertical="16dp"
            android:background="@drawable/marco_color_bt">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="10dp">

                <LinearLayout
                    android:paddingTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textColor="@color/colorClaro"
                        android:text="Comentarios"
                        android:padding="3dp"/>

                </LinearLayout>



                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Envía tus comentarios o sugerencias sobre la App:"
                    android:textSize="18sp"
                    android:textColor="@color/colorClaro"
                    android:padding="3dp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/edt_comentarios"
                    android:gravity="top"
                    android:layout_marginHorizontal="3dp"
                    android:padding="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@color/colorA"
                    android:inputType="textMultiLine|textCapSentences"
                    android:textColor="@color/colorClaro" />
                <Button
                    android:id="@+id/btn_send"
                    android:text="Enviar"
                    android:background="@drawable/button2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:textColor="@color/colorClaro"/>


            </LinearLayout>

        </LinearLayout>




    </ScrollView>



    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_ajustes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Arrow"
        android:background="@color/fui_transparent"/>


</androidx.coordinatorlayout.widget.CoordinatorLayout>

