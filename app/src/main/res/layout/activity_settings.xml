<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/zibe_night_start"
    android:orientation="vertical"
    android:layout_gravity="center">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:isScrollContainer="true">



        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:animateLayoutChanges="true"
            android:fillViewport="true"
            android:id="@+id/scrollable">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">





                <LinearLayout
                    android:layout_marginVertical="50dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="16dp"
                    android:background="@drawable/marco_color_bt">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="10dp">

                        <LinearLayout
                            android:paddingTop="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/fui_ic_anonymous_white_24dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="18sp"
                                android:text="Cuenta"
                                android:paddingStart="3dp"/>

                        </LinearLayout>

                        <TextView
                            android:gravity="center"
                            android:id="@+id/my_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorD"
                            android:textStyle="bold"
                            android:padding="3dp"/>


                        <LinearLayout
                            android:id="@+id/btn_change_email"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="7dp"
                            android:background="@color/colorC"
                            android:gravity="center"
                            android:layout_margin="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:text="CAMBIAR EMAIL"
                                android:textSize="@dimen/text_size_normal"
                                android:textAlignment="center"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="@color/colorClaro"/>

                            <ImageView
                                android:id="@+id/arrow_down_change_email"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_baseline_keyboard_arrow_down_24"/>
                            <ImageView
                                android:id="@+id/arrow_up_change_email"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_baseline_keyboard_arrow_up_24"/>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/linearChangeEmail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:orientation="horizontal">

                                    <com.google.android.material.textfield.TextInputLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        app:passwordToggleDrawable="@drawable/icon_selector"
                                        app:passwordToggleEnabled="true"
                                        app:passwordToggleTint="@color/colorClaro">

                                        <com.google.android.material.textfield.TextInputEditText
                                            android:id="@+id/edt_password_email"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:hint="Contraseña"
                                            android:inputType="textPassword"
                                            android:textColor="@color/colorClaro"/>

                                    </com.google.android.material.textfield.TextInputLayout>


                                </LinearLayout>


                                <com.google.android.material.textfield.TextInputLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:passwordToggleTint="@color/colorPrimary">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/edt_new_mail"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:hint="Nuevo Email"
                                    android:inputType="text"
                                    android:textColor="@color/colorClaro"/>

                                </com.google.android.material.textfield.TextInputLayout>


                            </LinearLayout>

                            <ImageButton
                                android:id="@+id/btn_save_email"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:src="@drawable/ic_baseline_save_24"
                                android:background="@drawable/button2"
                                android:layout_marginBottom="7dp"
                                android:layout_marginHorizontal="5dp"/>


                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btn_change_password"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="7dp"
                            android:background="@color/colorC"
                            android:gravity="center"
                            android:layout_margin="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:text="CAMBIAR CONTRASEÑA"
                                android:textSize="@dimen/text_size_normal"
                                android:textAlignment="center"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="@color/colorClaro"/>

                            <ImageView
                                android:id="@+id/arrow_down_change_pass"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_baseline_keyboard_arrow_down_24"/>
                            <ImageView
                                android:id="@+id/arrow_up_change_pass"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_baseline_keyboard_arrow_up_24"/>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/linearChangePassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:orientation="horizontal">

                                    <com.google.android.material.textfield.TextInputLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        app:passwordToggleDrawable="@drawable/icon_selector"
                                        app:passwordToggleEnabled="true"
                                        app:passwordToggleTint="@color/colorClaro">

                                        <com.google.android.material.textfield.TextInputEditText
                                            android:id="@+id/edt_password_pass"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:hint="Contraseña"
                                            android:inputType="textPassword"
                                            android:textColor="@color/colorClaro"/>

                                    </com.google.android.material.textfield.TextInputLayout>


                                </LinearLayout>


                                <com.google.android.material.textfield.TextInputLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:passwordToggleDrawable="@drawable/icon_selector"
                                    app:passwordToggleEnabled="true"
                                    app:passwordToggleTint="@color/colorClaro">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/edt_new_pass"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:hint="Nueva Contraseña"
                                        android:inputType="textPassword"
                                        android:textColor="@color/colorClaro"/>

                                </com.google.android.material.textfield.TextInputLayout>


                            </LinearLayout>

                            <ImageButton
                                android:id="@+id/btn_save_pass"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:src="@drawable/ic_baseline_save_24"
                                android:background="@drawable/button2"
                                android:layout_marginBottom="7dp"
                                android:layout_marginHorizontal="5dp"/>


                        </LinearLayout>

                        <Button
                            android:id="@+id/btn_logout"
                            android:text="Cerrar sesión"
                            android:backgroundTint="@color/colorC"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorClaro"/>

                        <LinearLayout
                            android:paddingTop="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_notifications_black_24dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="18sp"
                                android:text="Notificaciones"
                                android:paddingStart="3dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="7dp"
                            android:background="@color/colorC"
                            android:gravity="center"
                            android:layout_margin="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:text="CHATS INDIVIDUALES"
                                android:textSize="@dimen/text_size_normal"
                                android:textAlignment="center"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"

                                android:textColor="@color/colorClaro"/>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switch_individualNotifications"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"/>

                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="7dp"
                            android:background="@color/colorC"
                            android:gravity="center"
                            android:layout_margin="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:text="CHATS GRUPALES"
                                android:textSize="@dimen/text_size_normal"
                                android:textAlignment="center"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="@color/colorClaro"/>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switch_groupNotifications"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"/>

                        </LinearLayout>


                        <LinearLayout
                            android:layout_margin="20dp"
                            android:paddingVertical="10dp"
                            android:paddingHorizontal="20dp"
                            android:layout_width="wrap_content"
                            android:background="@drawable/marco_blanco"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingEnd="10dp"
                                android:src="@mipmap/logo"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="15sp"
                                    android:textColor="@color/colorF"
                                    android:text="Zibe App"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="12sp"
                                    android:textColor="@color/colorF"
                                    android:text="Versión Beta"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="12sp"
                                    android:textColor="@color/colorF"
                                    android:text="2020"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="12sp"
                                    android:textColor="@color/colorF"
                                    android:text="ZibeteProyects"/>

                            </LinearLayout>

                        </LinearLayout>

                        <Button
                            android:id="@+id/btn_report"
                            android:text="Enivar comentarios"
                            android:backgroundTint="@color/zibe_night_start"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorClaro"/>

                        <Button
                            android:id="@+id/btn_delete_account"
                            android:text="Eliminar Cuenta"
                            android:backgroundTint="@color/zibe_night_start"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/colorClaro"/>

                    </LinearLayout>

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="50dp"/>

            </LinearLayout>


        </ScrollView>

    </LinearLayout>



    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_ajustes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Arrow"
        android:background="@color/transparent"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

