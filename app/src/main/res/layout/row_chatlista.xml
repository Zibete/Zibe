<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="5dp"
        android:layout_marginTop="2dp"
        app:cardCornerRadius="8dp"
        app:cardBackgroundColor="@color/zibe_night_start">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="2dp">

            <!-- Avatar -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/image_user1"
                android:layout_width="@dimen/img_chatlist_size_normal"
                android:layout_height="@dimen/img_chatlist_size_normal"
                android:padding="5dp" />

            <!-- Contenido principal -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <!-- Fila superior: nombre + estado + notif + no vistos -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Nombre + estado -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_usuario1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="5dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:singleLine="true"
                            android:textSize="@dimen/text_size_large" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/icon_connected"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_circle_online" />

                            <ImageView
                                android:id="@+id/icon_disconnected"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ic_circle_offline" />

                            <TextView
                                android:id="@+id/tv_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="4dp"
                                android:textSize="@dimen/text_size_small" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Icono notificaciones silenciadas -->
                    <ImageView
                        android:id="@+id/notif_off"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:src="@drawable/ic_baseline_notifications_off_24" />

                    <!-- Contenedor burbuja no leídos -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/chat_left"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/nuevo_msg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="9dp"
                            android:layout_marginRight="9dp"
                            android:text="1"
                            android:textSize="22sp"
                            android:textAlignment="center" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Fila inferior: checks + último mensaje + hora -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="5dp"
                    android:paddingBottom="2dp">

                    <!-- Checks -->
                    <RelativeLayout
                        android:id="@+id/relativeLayout"
                        android:layout_width="20dp"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/checked"
                            android:layout_width="15dp"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_check_24" />

                        <ImageView
                            android:id="@+id/checked2"
                            android:layout_width="15dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:src="@drawable/ic_check_24" />
                    </RelativeLayout>

                    <!-- Último mensaje -->
                    <TextView
                        android:id="@+id/ult_msg"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="5dp"
                        android:singleLine="true"
                        android:textColor="@color/colorClaro"
                        android:textSize="@dimen/text_size_normal" />

                    <!-- Hora último mensaje -->
                    <TextView
                        android:id="@+id/hora_ult_msg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:textColor="@color/colorClaro"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
