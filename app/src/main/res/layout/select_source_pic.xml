<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sheet_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding"
    android:paddingTop="10dp">

    <!-- Header: título + cerrar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Editar foto"
            android:textAlignment="center"
            android:textColor="@color/accent"
            android:textAppearance="@style/Zibe.Text.Brand.Medium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close"
            style="@style/Zibe.IconButton"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/transparent"
            android:contentDescription="@string/close"
            app:icon="@drawable/ic_baseline_close_24" />

    </LinearLayout>

    <!-- Cuerpo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Fila de acciones -->
        <LinearLayout
            android:id="@+id/actions_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/element_spacing_medium">

            <!-- Card: Eliminar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_delete_profile_photo_selected"
                style="@style/Zibe.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/element_spacing_xs"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/element_spacing_small">

                    <ImageView
                        android:id="@+id/icon_trash"
                        android:layout_width="@dimen/zibe_btn_height"
                        android:layout_height="@dimen/zibe_btn_height"
                        android:contentDescription="@string/delete"
                        app:srcCompat="@drawable/ic_baseline_delete_24"
                        app:tint="@color/zibe_button_text_selector" />

                    <TextView
                        android:textAppearance="@style/Zibe.Text.Regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/element_spacing_xs"
                        android:text="@string/delete"
                        android:textColor="@color/zibe_button_text_selector" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Cámara -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_camera_selected"
                style="@style/Zibe.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/element_spacing_xs"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/element_spacing_small">

                    <ImageView
                        android:id="@+id/icon_camera"
                        android:layout_width="@dimen/zibe_btn_height"
                        android:layout_height="@dimen/zibe_btn_height"
                        android:contentDescription="@string/camera"
                        app:srcCompat="@drawable/ic_menu_camera"
                        app:tint="@color/zibe_button_text_selector" />

                    <TextView
                        android:textAppearance="@style/Zibe.Text.Regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/element_spacing_xs"
                        android:text="@string/camera"
                        android:textColor="@color/zibe_button_text_selector" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Galería -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_gallery_selected"
                style="@style/Zibe.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/element_spacing_xs"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/element_spacing_small">

                    <ImageView
                        android:id="@+id/icon_gallery"
                        android:layout_width="@dimen/zibe_btn_height"
                        android:layout_height="@dimen/zibe_btn_height"
                        android:contentDescription="@string/gallery"
                        app:srcCompat="@drawable/ic_menu_gallery"
                        app:tint="@color/zibe_button_text_selector" />

                    <TextView
                        android:textAppearance="@style/Zibe.Text.Regular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/element_spacing_xs"
                        android:text="@string/gallery"
                        android:textColor="@color/zibe_button_text_selector" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
