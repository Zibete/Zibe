<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/accent_transparent">

    <!-- contenido con selector de estados -->
    <item>
        <inset
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:insetTop="0dp">
            <selector>
                <!-- Presionado -->
                <item android:state_pressed="true" android:drawable="@drawable/selector_header_row"/>
                <!-- Activado -->
                <item android:state_activated="true" android:drawable="@drawable/selector_header_row"/>
                <!-- Foco -->
                <item android:state_focused="true" android:drawable="@drawable/selector_header_row"/>
                <!-- Default -->
                <item android:drawable="@drawable/bg_surface_row"/>
            </selector>
        </inset>
    </item>

    <!-- máscara para mantener el ripple redondeado -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</ripple>
