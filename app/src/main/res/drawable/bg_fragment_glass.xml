<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradiente translúcido -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="40"
                android:startColor="#994A148C"
                android:centerColor="#806B1FAF"
                android:endColor="#80233B99"
                android:type="linear" />
        </shape>
    </item>

    <!-- Capa superior de sombreado sutil -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A000000" /> <!-- 10% negro -->
        </shape>
    </item>
</layer-list>
