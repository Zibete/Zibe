<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Estado presionado -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:startColor="@color/zibe_blue"
                android:endColor="@color/zibe_pink"
                android:angle="45"/>
            <stroke
                android:width="1dp"
                android:color="#40FFFFFF"/> <!-- leve brillo -->
        </shape>
    </item>

    <!-- Estado normal -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:startColor="@color/zibe_blue"
                android:endColor="@color/zibe_pink"
                android:angle="45"/>
            <stroke
                android:width="1dp"
                android:color="#26FFFFFF"/> <!-- borde translúcido -->

        </shape>
    </item>

</selector>
