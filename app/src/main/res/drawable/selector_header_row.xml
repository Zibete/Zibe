<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Presionado -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/zibe_overlay" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Activado (si marcÃ¡s activated en cÃ³digo al expandir) -->
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/zibe_overlay" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="@color/zibe_gradient_end" />
        </shape>
    </item>

    <!-- Foco (teclado/TV) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/zibe_overlay" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Default -->
    <item android:state_pressed="false" android:state_activated="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/zibe_surface" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>


