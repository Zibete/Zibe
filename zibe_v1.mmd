%% ==== ZIBE APP STRUCTURE v1 (layout optimizado) ====
flowchart TD

%% ---- Estilos ----
classDef object fill:#e0e0e0,stroke:#555,stroke-width:1px,color:#111;
classDef string fill:#d0e8ff,stroke:#2b6cb0,color:#0b2c4a;
classDef number fill:#d9f7d6,stroke:#2f855a,color:#0b3d2e;
classDef boolean fill:#ffe9c2,stroke:#b7791f,color:#5a3a00;
classDef id fill:#fbd3e9,stroke:#b83280,color:#521437;

%% ====================================================
%% ====================== CHATS ========================
%% ====================================================
subgraph CHATS["💬 CHATS"]
direction TB
    A["Chats"]:::object --> A1["id <--> id (desde java/kt)"]:::object
    A1 --> M["Mensajes"]:::object
    M --> MID["Id push (desde java/kt)"]:::object
    MID --> d1["date: string"]:::string
    MID --> e1["envia: id"]:::id
    MID --> m1["mensaje: string"]:::string
    MID --> t1["type: number"]:::number
    MID --> v1["visto: number"]:::number
end

%% ====================================================
%% ====================== GROUPS =======================
%% ====================================================
subgraph GROUPS["👥 GROUPS"]
direction TB

    %% Chat (mensajes)
    subgraph GroupChat["Chat"]
    direction TB
        GC1["Nombre del grupo (desde java/kt)"]:::object --> GPush["Id push (desde java/kt)"]:::object
        GPush --> gd["date: string"]:::string
        GPush --> gid["id: id"]:::id
        GPush --> gmsg["mensaje: string"]:::string
        GPush --> gname["name: string"]:::string
        GPush --> gtmsg["type_msg: number"]:::number
        GPush --> gtuser["type_user: number"]:::number
    end

    %% Data (metadatos)
    subgraph GroupData["Data"]
    direction TB
        GDN["Nombre del grupo (desde java/kt)"]:::object
        GDN --> cat["category: number"]:::number
        GDN --> data["data: string"]:::string
        GDN --> dateC["dateCreate: string"]:::string
        GDN --> creator["id_creator: id"]:::id
        GDN --> name["name: string"]:::string
        GDN --> users["users: number"]:::number
    end

    %% Users (miembros)
    subgraph GroupUsers["Users"]
    direction TB
        GUN["Nombre del grupo (desde java/kt)"]:::object
        GUN --> GUid["Id (desde java/kt)"]:::object
        GUid --> type["type: number"]:::number
        GUid --> uid["user_id: id"]:::id
        GUid --> uname["user_name: string"]:::string
    end
end

%% ====================================================
%% ===================== USUARIOS ======================
%% ====================================================
subgraph USERS["👤 USUARIOS"]
direction TB

    %% Cuentas
    subgraph Profiles["Cuentas"]
    direction TB
        Uid["Id"]:::object
        Uid --> age["age: number"]:::number
        Uid --> birth["birthDay: string"]:::string
        Uid --> date["date: string"]:::string
        Uid --> desc["descripcion: string"]:::string
        Uid --> dist["distance: number"]:::number
        Uid --> state["estado: boolean"]:::boolean
        Uid --> fcm["fcmToken: string"]:::string
        Uid --> foto["foto: string (URL)"]:::string
        Uid --> idd["id: id"]:::id
        Uid --> inst["installId: string"]:::string
        Uid --> lat["latitud: number"]:::number
        Uid --> lng["longitud: number"]:::number
        Uid --> mail["mail: string"]:::string
        Uid --> nom["nombre: string"]:::string
        Uid --> tok["token: string"]:::string
    end

    %% Datos
    subgraph Data["Datos"]
    direction TB
        DId["Id (desde java/kt)"]:::object

        %% ChatList
        subgraph ChatList["ChatList"]
        direction TB
            actual["Actual: string"]:::string
            readGroup["msgReadGroup: number"]:::number
        end

        %% ChatWith
        subgraph ChatWith["ChatWith"]
        direction TB
            CWid["Id (desde java/kt)"]:::object
            CWid --> c_estado["estado: string"]:::string
            CWid --> c_noVisto["noVisto: number"]:::number
            CWid --> c_wDate["wDate: string"]:::string
            CWid --> c_wEnvia["wEnvia: id"]:::id
            CWid --> c_wMsg["wMsg: string"]:::string
            CWid --> c_wUserID["wUserID: id"]:::id
            CWid --> c_wUserName["wUserName: string"]:::string
            CWid --> c_wUserPhoto["wUserPhoto: string"]:::string
            CWid --> c_wVisto["wVisto: number"]:::number
        end

        %% Estado
        subgraph Estado["Estado"]
        direction TB
            e_estado["estado: string"]:::string
            e_fecha["fecha: string"]:::string
            e_hora["hora: string"]:::string
        end

        %% Favoritos
        subgraph Favorites["FavoriteList"]
        direction TB
            fav["Id (desde java/kt)"]:::id
        end
    end
end

%% ====================================================
%% =================== ZIBE COMENTARIOS ================
%% ====================================================
subgraph ZIBE_COMMENTS["🗨️ ZIBE / Comentarios"]
direction TB
    ZRoot["Zibe"]:::object --> ZCom["Comentarios"]:::object
    ZCom --> ZYear["año (desde java/kt)"]:::object
    ZYear --> ZMonth["mes (desde java/kt)"]:::object
    ZMonth --> ZDay["día (desde java/kt)"]:::object
    ZDay --> ZHour["HH:MM:ss (desde java/kt)"]:::object
    ZHour --> zid["ID: id"]:::id
    ZHour --> zmail["email: string"]:::string
    ZHour --> zmsg["mensaje: string"]:::string
    ZHour --> znom["nombre: string"]:::string
end

%% ====================================================
%% =================== LEYENDA =========================
%% ====================================================
subgraph LEGEND
direction LR
  L1["id"]:::id
  L2["string"]:::string
  L3["number"]:::number
  L4["boolean"]:::boolean
  L5["object"]:::object
end
